WIFI_SSID=your-ssid
WIFI_PASS=your-password
WIFI_CONFIG_PATH=wifi_networks.json
GLOVE_ID=primary_glove
PICO_API_TOKEN=replace-with-pico-token
# Prefer wss:// for public/central control-plane connections.
GLOVE_WS_URL=wss://your-backend.example.dev/glove
CA_DER_PATH=certs/central-ca.der
ENDPOINT_CACHE_PATH=endpoint_cache.json
TOP_FSR_PIN=27
BOTTOM_FSR_PIN=26
CALIBRATION_SAMPLES=50
BATTERY_LABEL=--
# Update metrics every 5 minutes to avoid excessive metrics
METRICS_INTERVAL_SEC=180
ACTION_SEND_INTERVAL_MS=250
