WIFI_SSID=your-ssid
WIFI_PASS=your-password
WIFI_CONFIG_PATH=wifi_networks.json

GLOVE_ID=primary_glove
PICO_API_TOKEN=replace-with-pico-token

# Central control-plane base URL. The firmware can derive HTTP API routes from this.
GLOVE_WS_URL=wss://your-backend.example.dev/glove
CA_DER_PATH=certs/central-ca.der
ENDPOINT_CACHE_PATH=endpoint_cache.json

# Hardware pins
TOP_FSR_PIN=27
BOTTOM_FSR_PIN=26

# FSR tuning
# Lower ratio = easier/faster activation. FULL threshold defaults to 0.4V * 0.55 = 0.22V.
FSR_HALF_RATIO=0.25
FSR_FULL_RATIO=0.55
FSR_SMOOTHING_SAMPLES=3
FSR_DEBOUNCE_MS=25
FSR_DOUBLE_CLICK_MS=280
FSR_HOLD_MS=450
FSR_HOLD_REPEAT_MS=160
# Optional per-pad overrides
# BOTTOM_FSR_FULL_RATIO=0.45

CALIBRATION_SAMPLES=50

# Battery / metrics
BATTERY_LABEL=--
# Update metrics every 5 minutes to avoid excessive metrics
METRIC_INTERVAL_SEC=300

# Action + networking timing
ACTION_SEND_INTERVAL_MS=30
ACTION_ACK_TIMEOUT_MS=5000
ACTION_QUEUE_MAX=16
ACTION_QUEUE_TIMEOUT_MS=8000
# Set to http to disable WSS action sends and use POST /api/gloves/:id/actions/... instead.
PICO_ACTION_TRANSPORT=http
PICO_HTTP_ACTION_FALLBACK=true
PICO_HTTP_ACTION_TIMEOUT_SEC=0.35
PICO_HTTPS_ACTION_TIMEOUT_SEC=5
PICO_HTTP_ACTION_ASYNC=true
PICO_HTTP_ACTION_DOWNGRADE_TLS=false
CONTINUOUS_ROLL_REQUIRES_FSR=true
CONTINUOUS_ROLL_FSR_SOURCE=any

# Loop intervals
FSR_LOOP_INTERVAL_MS=20
UI_LOOP_INTERVAL_MS=150
NETWORK_LOOP_INTERVAL_MS=20
TIMING_LOG_INTERVAL_MS=5000

# WebSocket
WS_HEARTBEAT_MS=20000

# Debugging
DEBUG=false
# DEBUG_LIST is case-insensitive: fsr, imu, roll, wifi, ws, action, or all.
# Empty means all debug targets when DEBUG=true.
DEBUG_LIST=fsr,imu,roll,wifi,ws,action
DEBUG_INTERVAL_MS=500
