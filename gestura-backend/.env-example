# Gestura Gauntlet — Backend Environment Variables
# Copy this to .env and fill in your values.

PORT=3001

# IP of the machine running Mosquitto (or any MQTT broker)
# If Mosquitto is on the same machine as this server, localhost works
MQTT_URL=mqtt://localhost:1883

# Local IP addresses of your Kasa devices
# Find these in the Kasa mobile app under Device Info
PLUG_IP=192.168.1.XXX
BULB_IP=192.168.1.XXX
