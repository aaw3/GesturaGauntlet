# Gestura Gauntlet — Backend Environment Variables
# Copy this to .env and fill in your values.

PORT=3001

# Port for the embedded MQTT broker (Pico connects here)
MQTT_BROKER_PORT=1883

# MQTT topics used by the glove firmware.
MQTT_TOPIC_SENSORS=gauntlet/sensors
MQTT_TOPIC_MODE=gauntlet/mode

# Dashboard sensor sample history retained by the backend.
SENSOR_HISTORY_SIZE=200

# Optional Postgres persistence. When unset, managers and configuration stay in memory.
DATABASE_URL=postgres://gestura:gestura@localhost:5432/gestura
DATABASE_SSL=false

# Optional node-agent authentication. If set, node agents must send this as NODE_TOKEN.
NODE_TOKEN=

# Optional Grafana annotation upload for telemetry. Leave unset to store telemetry only in Postgres/memory.
GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_ORG_ID=

# Node-agent process examples:
# CENTRAL_API_URL=http://localhost:3001
# CENTRAL_WS_URL=http://localhost:3001
# NODE_ID=pi-edge-1
# NODE_NAME=Pi Edge 1
# NODE_TOKEN=
# NODE_LAN_URL=http://192.168.1.25:3201
