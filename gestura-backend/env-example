# Gestura Gauntlet — Backend Environment Variables
# Copy this to .env and fill in your values.

PORT=3001

# Port for the embedded MQTT broker (Pico connects here)
MQTT_BROKER_PORT=1883

# MQTT topics used by the glove firmware.
MQTT_TOPIC_SENSORS=gauntlet/sensors
MQTT_TOPIC_MODE=gauntlet/mode

# Dashboard sensor sample history retained by the backend.
SENSOR_HISTORY_SIZE=200

# Optional Postgres persistence. When unset, managers and configuration stay in memory.
DATABASE_URL=postgres://gestura:gestura@localhost:5432/gestura
DATABASE_SSL=false
