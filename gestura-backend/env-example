# Gestura Gauntlet — Backend Environment Variables
# Copy this to .env and fill in your values.

PORT=3001

# Dashboard sensor sample history retained by the backend.
SENSOR_HISTORY_SIZE=200

# Optional Postgres persistence. When unset, managers and configuration stay in memory.
DATABASE_URL=postgres://gestura:gestura@localhost:5432/gestura
DATABASE_SSL=false

# Dashboard session auth. DASHBOARD_PASSWORD_HASH uses:
# scrypt$<salt_hex>$<derived_key_hex>
SESSION_SECRET=replace-with-long-random-secret
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=

# Service-to-service auth.
NODE_SHARED_TOKEN=replace-with-node-shared-secret
PICO_API_TOKEN=replace-with-pico-bearer-token
# Plain websocket endpoint for Pico:
# ws://localhost:3001/glove?gloveId=primary_glove&api_key=<PICO_API_TOKEN>
# Use wss:// when the control plane is behind TLS.

# Optional per-node token map instead of NODE_SHARED_TOKEN.
# NODE_TOKEN_MAP={"pi-edge-1":"secret-1","pi-edge-2":"secret-2"}

# Optional InfluxDB telemetry upload. Leave unset to store telemetry only in Postgres/memory.
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=replace-with-influx-token
INFLUXDB_ORG=gestura
INFLUXDB_BUCKET=gestura_metrics
GLOVE_STATUS_TELEMETRY_INTERVAL_MS=5000

# Node-agent process examples:
# CENTRAL_API_URL=http://localhost:3001
# CENTRAL_WS_URL=http://localhost:3001
# NODE_ID=pi-edge-1
# NODE_NAME=Pi Edge 1
# NODE_TOKEN=replace-with-node-shared-secret
# NODE_LAN_URL=http://192.168.1.25:3201
# NODE_AGENT_PORT=3201
# MANAGER_SHARED_TOKEN=replace-with-manager-shared-secret
# MANAGER_TOKEN_MAP={"kasa-main":"token-a","sim-main":"token-b"}

# Manager process examples:
# NODE_AGENT_WS_URL=http://localhost:3201
# MANAGER_ID=kasa-main
# MANAGER_KIND=kasa
# MANAGER_NAME=Kasa Main
# MANAGER_TOKEN=replace-with-manager-shared-secret
# MANAGER_ICON_KEY=lightbulb
# MANAGER_COLOR_KEY=amber
# MANAGER_LAN_URL=http://192.168.1.25:3301
# MANAGER_PUBLIC_URL=

# Simulator manager proxy:
# SIMULATOR_API_URL=http://localhost:3000
